# LLM provider: "ollama" for local dev, "anthropic" for production
LLM_PROVIDER=ollama

# Required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-api-key-here

# Ollama model name (must be pulled locally)
OLLAMA_MODEL=llama3

# Anthropic model name
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Path to your Chroma vector store
CHROMA_DB_PATH=./chroma_db

# Path to your source documents
DATA_PATH=./data
